{
  "expo": {
    "name": "RunningApp",
    "slug": "running-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "running-app",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1A1A2E",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.runningapp.mobile",
      "usesAppleSignIn": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-web-browser"
    ]
  }
}
